POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=easyrice_db
DB_HOST=localhost
DB_PORT=5432

PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=admin
PGADMIN_PORT=8080



